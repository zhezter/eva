{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EVA",
  "version": "0.1.0",
  "identifier": "com.eva.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EVA",
        "width": 900,
        "height": 700,
        "minWidth": 280,
        "minHeight": 40,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
